# LLM Configuration
OPENAI_API_KEY=your_openai_key
ANTHROPIC_API_KEY=your_anthropic_key
LLM_MODEL=gpt-4-turbo-preview

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/incident_response
MONGODB_URI=mongodb://localhost:27017/incident_db
REDIS_URL=redis://localhost:6379/0

# Slack Integration
SLACK_BOT_TOKEN=xoxb-your-token
SLACK_SIGNING_SECRET=your_signing_secret

# Microsoft Teams Integration
TEAMS_APP_ID=your_teams_app_id
TEAMS_APP_PASSWORD=your_app_password

# AWS Configuration
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_DEFAULT_REGION=us-east-1

# Azure Configuration
AZURE_SUBSCRIPTION_ID=your_subscription
AZURE_CLIENT_ID=your_client_id
AZURE_CLIENT_SECRET=your_client_secret

# Google Cloud Configuration
GOOGLE_APPLICATION_CREDENTIALS=path/to/credentials.json

# Monitoring Tools
DATADOG_API_KEY=your_datadog_key
NEW_RELIC_API_KEY=your_new_relic_key
ELASTIC_HOST=localhost:9200

# GitHub Integration
GITHUB_TOKEN=your_github_token
GITHUB_ORG=your_organization

# Knowledge Base
INCIDENT_MEMORY_DB=memory.json
KB_SIMILARITY_THRESHOLD=0.7
MAX_HISTORICAL_INCIDENTS=1000

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# API Server
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false

# Agent Configuration
INVESTIGATION_TIMEOUT=300
MAX_CONCURRENT_INVESTIGATIONS=5
ENABLE_AUTO_INVESTIGATION=true

# Feature Flags
ENABLE_SLACK_BOT=true
ENABLE_TEAMS_BOT=false
ENABLE_AUTO_INCIDENTS=true
ENABLE_LEARNING=true
